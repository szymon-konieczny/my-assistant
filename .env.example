# Anthropic API key for invoice data extraction
ANTHROPIC_API_KEY=sk-ant-...

# KSeF token (Polish e-invoicing system)
KSEF_TOKEN=

# Gmail OAuth (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Or use a credentials.json file locally (optional, env vars take priority)
GMAIL_CREDENTIALS_FILE=credentials.json

# Comma-separated list of Gmail account aliases
# Each account needs OAuth consent on first run
# Token files stored in tokens/{alias}.json
GMAIL_ACCOUNTS=szykon,progrise

# Accounting partner email (draft recipient)
ACCOUNTING_EMAIL=biuro@silesia-tax.pl

# Senders to exclude from scanning (comma-separated)
EXCLUDED_SENDERS=biuro@silesia-tax.pl

# Invoice PDF storage directory
INVOICE_STORAGE_DIR=invoices

# SQLite database path
DATABASE_PATH=invoices.db

# Claude model for invoice parsing
CLAUDE_MODEL=claude-sonnet-4-20250514

# Monthly scan schedule (day of month, hour, minute)
SCAN_CRON_DAY=5
SCAN_CRON_HOUR=9
SCAN_CRON_MINUTE=0

# Server
HOST=0.0.0.0
PORT=8000

# Base URL for OAuth redirect (set to your Railway URL in production)
# e.g. https://your-app.railway.app
BASE_URL=http://localhost:8000
